{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",

    "module": "commonjs",
    "target": "ES2022",
    "moduleResolution": "node",
    "lib": ["esnext"],
    "types": ["node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "moduleDetection": "force",
    "isolatedModules": true
  },
  "include": [
  "src/index.ts",
  "src/routes/filiereRoute.ts",
  "src/controllers/filiereController.ts",
  "src/middlewares/authorize.ts",
  "src/prismaClient.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
